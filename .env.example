# ──────────────────────────────────────────────────────────────────────────────
# Einsatzleiter SMS-Gateway – Konfiguration
# Datei nach .env kopieren und anpassen.
# ──────────────────────────────────────────────────────────────────────────────

# Verbindung zur Einsatzleiter-Haupt-App
# Domain ohne Protokoll (z.B. einsatzleiter.feuerwehr-wolfurt.at)
GATEWAY_DOMAIN=einsatzleiter.feuerwehr-wolfurt.at

# Connection-Token (aus: python -m app.cli create-sms-gateway-token --label "Modem Wolfurt")
GATEWAY_TOKEN=smsgw_...

# TLS verwenden? true für Produktion (wss://), false nur für lokale Entwicklung (ws://)
GATEWAY_USE_TLS=true

# ── Modem-Einstellungen (CoNiuGo SMS Gateway LTE) ─────────────────────────────

# IP-Adresse oder Hostname des Modems im lokalen Netz
MODEM_URL=http://192.168.1.1/cgi-bin/sendsms

# HTTP-Methode: GET oder POST
MODEM_METHOD=GET

# Query-String-Template für GET-Requests (Platzhalter: {to} = Nummer, {text} = Nachricht)
# Beide werden URL-encodiert eingesetzt.
MODEM_QUERY=nr={to}&text={text}

# Body-Template für POST-Requests (leer = Query-Params als Form-Body)
MODEM_BODY=

# Optional: HTTP Basic-Auth (Format: benutzer:passwort, leer = keine Auth)
MODEM_BASIC_AUTH=

# Timeout in Sekunden für den Modem-HTTP-Request
MODEM_TIMEOUT=10.0

# TLS-Zertifikat des Modems prüfen? Für interne HTTP-Modems auf false setzen.
MODEM_VERIFY_TLS=false

# ── Reconnect / Heartbeat (Standardwerte in der Regel ausreichend) ─────────────
# RECONNECT_INITIAL_DELAY=1.0
# RECONNECT_MAX_DELAY=30.0
# HEARTBEAT_INTERVAL=20.0
# SMS_RESULT_TIMEOUT=15.0
